    "@opennextjs/cloudflare": "^1.18.0",
    "drizzle-orm": "^0.45.1",
    "html2canvas": "^1.4.1",
    "nanoid": "^3.3.11",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.58.2",
